ARG BASE_IMAGE="us-docker.pkg.dev/ml-oss-artifacts-transient/torch-tpu-docker-container/torchtpu-vllm-ci:latest"

FROM $BASE_IMAGE

# Install benchmark system utilities
RUN apt-get update && apt-get install -y \
    rclone \
    netcat-openbsd \
    bc \
    vim-common \
    && rm -rf /var/lib/apt/lists/*

# Install TorchTPU vllm from local source (identical to dev target in official Dockerfile)
WORKDIR /root/torchtpu-vllm
COPY . .
RUN --mount=type=cache,target=/root/.cache/uv \
    SETUPTOOLS_SCM_PRETEND_VERSION=0.0.0 \
    uv pip install --system --no-config --override /tmp/overrides.txt --index-url https://pypi.org/simple -e ".[test,benchmarking]"

# Clone upstream vllm repository to have benchmark files (without compiling it)
# This also provides the correct git history for validation checks in agent scripts
WORKDIR /workspace/vllm
ARG VLLM_REPO=https://github.com/vllm-project/vllm.git
ARG VLLM_VERSION
RUN git clone $VLLM_REPO . && \
    if [ -n "$VLLM_VERSION" ]; then git checkout $VLLM_VERSION; fi

CMD ["/bin/bash"]
